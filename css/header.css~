/* ========== header.css ========== */
/* Шапка и навигация */

.header {
    padding: 20px 0;
}

.nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    padding: 2%;
}

.nav-left, .nav-right {
    display: flex;
    gap: 100px;
}

.nav-btn {
    background: var(--accent);
    color: white;
    text-decoration: none;
    padding: 12px 24px;
    border-radius: 100px;
    font-weight: 600;
    font-size: 16px;
    transition: opacity 0.2s;
}

.nav-btn:hover {
    opacity: 0.9;
}

.nav-btn.active {
    background: #2a8ad4;
    box-shadow: 0 4px 10px rgba(70, 178, 255, 0.3);
}

.logo img {
    height: 50px;
    width: auto;
}