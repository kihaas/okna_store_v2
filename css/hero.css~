/* ========== hero.css ========== */
/* Первый экран с фото и текстом */

.hero {
    position: relative;
    overflow: hidden;
}

.hero .container {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-height: 450px;
}

/* Белый контейнер для фото */
.hero-content {
    position: absolute;
    right: 550px;
    top: 20px;
    width: 683px;
    height: 411px;
    background: var(--white);
    border-radius: 86px;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 20px 40px rgba(0,0,0,0.05);
}

/* Блок с фото */
.hero-images {
    position: relative;
    width: 100%;
    height: 100%;
}

.image-stack {
    position: relative;
    width: 100%;
    height: 100%;
}

.image {
    position: absolute;
    border-radius: 109px;
    object-fit: cover;
    box-shadow: 0 15px 30px rgba(0,0,0,0.1);
}

/* Верхнее фото */
.image-front {
    width: 519px;
    height: 339px;
    top: 50%;
    left: 65%;
    transform: translate(-80%, -50%);
    z-index: 2;
    border-radius: 109px;
}

/* Нижнее фото */
.image-back {
    width: 358px;
    height: 333px;
    top: 30%;
    left: 35%;
    transform: translate(20%, -30%);
    z-index: 1;
    border-radius: 108px;
}

/* Текстовая часть */
.hero-text {
    position: absolute;
    right: -10px;
    top: 30%;
    transform: translateY(-30%);
    width: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

.hero-title {
    align-items: center;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: 40px !important;
    line-height: 1;
    color: var(--accent);
    margin-bottom: 10px;
    text-transform: uppercase;
    width: 100%;
    white-space: nowrap;
}

.hero-subtitle {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: 30px !important;
    line-height: 1;
    color: var(--text);
    margin-bottom: 30px;
    width: 100%;
}

.promo-block {
    position: absolute;
    right: 50px;
    background: var(--accent);
    border-radius: 74px;
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 50px;
}

.promo-badge {
    color: white;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: 26px;
    line-height: 1;
    white-space: nowrap;
}

.promo-btn {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(90deg, #0095FF 0%, #46B2FF 53%, #86CDFF 100%);
    color: white;
    text-decoration: none;
    width: 200px;
    height: 80px;
    border-radius: 62.5px;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: 32px;
    line-height: 1;
    margin-right: -30px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    right: 200px;
    top: 280px;
}

.promo-btn:hover {
    transform: scale(1.02);
    box-shadow: 0 6px 20px rgba(70, 178, 255, 0.3);
}